#!/bin/sh

ls() {
	if [ -z "$name" ]; then
		docker compose ls
	elif [ -z "$id" ]; then
		echo "$name stopped"
	else
		echo "$name running"
	fi
}

pull() {
	if [ -z "$name" ]; then
		for f in $folder/*.yaml
		do
			name=$(basename "$f" .yaml)
			docker compose -f "$f" pull
		done
	else
		docker compose -f "$folder/$name.yaml" pull
	fi
}

stop() {
	if [ -z "$name" ]; then
		for f in $folder/*.yaml
		do
			name=$(basename "$f" .yaml)
			docker compose -f "$f" -p "$name" stop
		done
	else
		docker compose -f "$folder/$name.yaml" -p "$name" stop
	fi
}

up() {
	if [ -z "$name" ]; then
		for f in $folder/*.yaml
		do
			name=$(basename "$f" .yaml)
			docker compose -f "$f" -p "$name" up -d
		done
	else
		docker compose -f "$folder/$name.yaml" -p "$name" up -d
	fi
}

help() {
	echo "Usage:"
	echo "  dockers [COMMAND] [NAME]"
	echo ""
	echo "Commands:"
	echo "  ls          List running compose projects"
	echo "  pull        Pull service images"
	echo "  stop        Stop services"
	echo "  up          Create and start containers"
}

folder="$HOME/.config/dockers"
name=$2
id=$(docker ps -qf "name=$name")

case "$1" in
	ls|pull|stop|up ) $1 ;;
	*               ) help ;;
esac

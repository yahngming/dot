#!/bin/sh

case "$@" in
	bc*                                                                              ) class="bottomright" ;;
	bat*|clean|dockers*|dot|*fetch*|impala|proxy*|rclone*|timezone*|*tui*|up|wiremix ) class="center" ;;
	asciiquarium*|lavat*|*matrix*|*svr                                               ) class="screensaver" ;;
	*                                                                                ) class="tui" ;;
esac
if [ -n "$WAYLAND_DISPLAY" ]; then
	if [ "$class" = "screensaver" ]; then
		theme="-o initial-color-theme=light"
	fi
	termcmd="foot $theme -a"
elif [ -n "$DISPLAY" ]; then
	termcmd="st -c"
fi
title="$(echo "$@" | cut -d ' ' -f 1)"

$termcmd $class -T $title -e $SHELL -c "$@"

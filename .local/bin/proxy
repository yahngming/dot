#!/bin/sh

proxy="mihomo"

case "$@" in
	disable ) sudo systemctl disable --now $proxy.service ;;
	enable  ) sudo systemctl enable --now $proxy.service ;;
	restart ) sudo systemctl restart $proxy.service ;;
	help    ) echo "Usage: proxy [disable|enable|restart|help]" ;;
	*       ) echo "$proxy $(systemctl is-active $proxy.service)" ;;
esac

#!/bin/sh

proxy="mihomo"
format="yaml"

get() {
	echo "$proxy $(systemctl is-active $proxy.service)"
}

off() {
	if [ -f ~/.config/proxy ]; then
		rm -f ~/.config/proxy
		gsettings set org.gnome.system.proxy mode "none"
		sudo systemctl disable --now $proxy.service
	fi
}

on() {
	if [ ! -f ~/.config/proxy ]; then
		touch -f ~/.config/proxy
		gsettings set org.gnome.system.proxy mode "manual"
		sudo systemctl enable --now $proxy.service
	fi
}

up() {
	cd ~/.local/src/sub
	git pull
	cd - >/dev/null 2>&1
	sudo cp ~/.local/src/sub/$proxy /etc/$proxy/config.$format
	if [ -f ~/.config/proxy ]; then
		sudo systemctl restart $proxy.service
	fi
}

help() {
	echo "Usage: proxy [get|off|on|up|help]"
}

case "$@" in
	off|on|up|help ) $@ ;;
	*              ) get ;;
esac

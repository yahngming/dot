#!/bin/sh

extension="$(printf "%s" "${1##*.}" | tr '[:upper:]' '[:lower:]')"
mimetype="$(file -Lb --mime-type -- "$1")"

case "$1" in
	https://www.youtube.com/*              ) pkill -f "Picture in picture"; setsid -f mpv --autofit=30% --title="Picture in picture" >/dev/null 2>&1 "$1" && exit ;;
	http*                                  ) setsid -f browser >/dev/null 2>&1 "$1" && exit ;;
esac

case "$extension" in
	1                                      ) man --local-file "$1" && exit ;;
	dff|diff                               ) delta --paging always < "$1" && exit ;;
	epub|pdf                               ) setsid -f zathura >/dev/null 2>&1 "$1" && exit ;;
	htm|html|xhtml                         ) w3m "$1" && exit ;;
	json                                   ) jq --color-output . "$1" | $PAGER && exit ;;
	md                                     ) glow --pager "$1" && exit ;;
esac

case "$mimetype" in
	*archive*|*compress*|*rar*|*tar*|*zip* ) als --page "$1" && exit ;;
	*audio*|*video*                        ) setsid -f mpv --force-window >/dev/null 2>&1 "$1" && exit ;;
	*document*                             ) setsid -f libreoffice >/dev/null 2>&1 "$1" && exit ;;
	*image*                                ) setsid -f nsxiv -a >/dev/null 2>&1 "$1" * && exit ;;
	*sqlite*                               ) (sqlite3 "$1" "SELECT name FROM sqlite_master WHERE type='table' AND name != 'sqlite_sequence';" 2>/dev/null | while read -r table; do sqlite3 -box "$1" "SELECT * FROM \`$table\`;" 2>/dev/null; done) | bat --color=always --style=plain --pager=always && exit ;;
	*text*|*xml*                           ) bat --paging always "$1" && exit ;;
esac

#!/bin/sh

menu="\
dwm\n\
hyprland\n\
mango\n\
niri\n\
xfce\n\
"

config="$HOME/.config/desktop"
desktop=$(awk '{print $NF; exit}' "$config")

case $(printf "$menu" | menu -p "$desktop in use" "$@") in
	dwm      ) echo "startx ~/.config/xorg/xinitrc dwm" > "$config" ;;
	hyprland ) echo "start-hyprland" > "$config" ;;
	mango    ) echo "exec mango" > "$config" ;;
	niri     ) echo "exec niri-session" > "$config" ;;
	xfce     ) echo "startx ~/.config/xorg/xinitrc xfce" > "$config" ;;
esac

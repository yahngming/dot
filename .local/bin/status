#!/bin/sh

bat() {
	bat="$(cat /sys/class/power_supply/BAT0/capacity)"
	case 1 in
		$((bat <= 10)) ) icon="َ°‚ƒ" ;;
		$((bat <= 20)) ) icon="َ°پ؛" ;;
		$((bat <= 30)) ) icon="َ°پ»" ;;
		$((bat <= 40)) ) icon="َ°پ¼" ;;
		$((bat <= 50)) ) icon="َ°پ½" ;;
		$((bat <= 60)) ) icon="َ°پ¾" ;;
		$((bat <= 70)) ) icon="َ°پ؟" ;;
		$((bat <= 80)) ) icon="َ°‚€" ;;
		$((bat <= 90)) ) icon="َ°‚پ" ;;
		$((bat <= 99)) ) icon="َ°‚‚" ;;
		$((bat >= 99)) ) icon="َ°پ¹" ;;
	esac
	[ "$icon" ] && printf "$icon"
}

clk() {
	clk="$(date '+%I')"
	case "$clk" in
		"00" ) icon="َ±‘ٹ" ;;
		"01" ) icon="َ±گ؟" ;;
		"02" ) icon="َ±‘€" ;;
		"03" ) icon="َ±‘پ" ;;
		"04" ) icon="َ±‘‚" ;;
		"05" ) icon="َ±‘ƒ" ;;
		"06" ) icon="َ±‘„" ;;
		"07" ) icon="َ±‘…" ;;
		"08" ) icon="َ±‘†" ;;
		"09" ) icon="َ±‘‡" ;;
		"10" ) icon="َ±‘ˆ" ;;
		"11" ) icon="َ±‘‰" ;;
		"12" ) icon="َ±‘ٹ" ;;
	esac
	clk="$(date '+%H:%M')"
	printf "$clk"
}

cpu() {
	cpu="$(($(cat /sys/class/thermal/thermal_zone0/temp)/1000))"
	case 1 in
		$((cpu <= 40)) ) icon="َ±ƒƒ" ;;
		$((cpu <= 80)) ) icon="َ°”ڈ" ;;
		$((cpu <= 99)) ) icon="َ±ƒ‚" ;;
	esac
	[ "$icon" ] && printf "$icon"
}

cut() {
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

dpm() {
	case "$(xset q | grep '^\s*DPMS is' | awk '{print $3}')" in
		Disabled ) printf "î°•" ;;
	esac
}

ime() {
	ime="$(fcitx5-remote -n)"
	case "$ime" in
		*anthy*|*kkc*|*mozc*|*skk* ) icon="ًں‡¯ًں‡µ" ;;
		*bi*|*ma*|*pin*            ) icon="ًں‡¨ًں‡³" ;;
		*hangul*                   ) icon="ًں‡°ًں‡·" ;;
		*                          ) icon="ًں‡؛ًں‡¸" ;;
	esac
	[ "$icon" ] && printf "$icon"
}

net() {
	net="$(iwctl station wlan0 show | grep '^\s*RSSI' | awk '{print $2}')"
	case 1 in
		$((net <= -80)) ) icon="َ°¤¯" ;;
		$((net <= -70)) ) icon="َ°¤ں" ;;
		$((net <= -60)) ) icon="َ°¤¢" ;;
		$((net <= -50)) ) icon="َ°¤¥" ;;
		$((net >= -50)) ) icon="َ°¤¨" ;;
	esac
	case "$(cat /sys/class/net/w*/operstate 2>/dev/null)" in
		down ) icon="َ°¤®" ;;
	esac
	case "$(cat /sys/class/net/e*/operstate 2>/dev/null)" in
		*up* ) icon="َ°ˆ€" ;;
	esac
	[ "$icon" ] && printf "$icon"
}

usb() {
	usb="$(df | grep '/media/')"
	[ "$usb" ] && printf "َ°•“"
}

vol() {
	vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"
	vol="${vol#'Volume: '}"
	vol="${vol%' [MUTED]'}"
	vol="$(printf "%.0f" "$(cut "$vol" ".")")"
	case 1 in
		$((vol <= 10)) ) icon="َ°•؟" ;;
		$((vol <= 80)) ) icon="َ°–€" ;;
		$((vol >= 80)) ) icon="َ°•¾" ;;
	esac
	case "$(wpctl get-volume @DEFAULT_AUDIO_SINK@)" in
		*MUTED* ) icon="َ°‌ں" ;;
	esac
	[ "$icon" ] && printf "$icon"
}

case "$DESKTOP" in
	*dwm*)
		while true; do
			sleep 0.5 && xprop -root -set WM_NAME " $(ime) $(usb) $(dpm) $(cpu) $(bat) $(net) $(vol) $(clk) "
		done
		;;
	*)
		echo "$(bat) $(net) $(vol)"
		;;
esac

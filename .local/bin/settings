#!/bin/sh

pkill $LAUNCHER && exit

case "$LAUNCHER" in
	fuzzel|walker ) opt="" ;;
	*             ) opt="-g 3 -l 7" ;;
esac

menu="\
≤▒κτ Audio\n\
Όφ┐ Bar\n\
≤░Γ│ Bluetooth\n\
≤░Δλ Clean\n\
Όχς Cloud\n\
Όας Desktop\n\
≤░Ξ╣ Display\n\
ΎΝΙ Docker\n\
ΎΗΤ Dotfiles\n\
Όψτ Fetch\n\
ΌυΒ IME\n\
ΌυΣ Password\n\
≤▒ηΗ Printer\n\
≤░Να Proxy\n\
ΌφΝ Screensaver\n\
≤░▓Β SMB\n\
≤░ΦΟ Theme\n\
≤▒λΔ Timezone\n\
≤░γ░ Update\n\
≤░ΧΥ USB\n\
≤░╕Κ Wallpaper\n\
≤▒γ╛ WLAN\n\
"

case $(printf "$menu" | menu $opt "$@") in
	*About*       ) pkill -f "read -n 1 -s"; tui "fastfetch | lolcat; read -n 1 -s" ;;
	*Audio*       ) audiomenu ;;
	*Bar*         ) barmenu ;;
	*Bluetooth*   ) btmenu ;;
	*Caffeine*    ) caffeinemenu ;;
	*Clean*       ) tui clean ;;
	*Cloud*       ) cloudmenu ;;
	*Desktop*     ) desktopmenu ;;
	*Display*     ) dispmenu ;;
	*Docker*      ) dockersmenu ;;
	*Dotfiles*    ) tui dot ;;
	*Fetch*       ) fetchmenu ;;
	*IME*         ) fcitx5-configtool ;;
	*Password*    ) passmenu ;;
	*Printer*     ) xdg-open http://127.0.0.1:631 ;;
	*Proxy*       ) proxymenu ;;
	*Screensaver* ) screensavermenu ;;
	*SMB*         ) smbmenu ;;
	*Theme*       ) thememenu ;;
	*Timezone*    ) timezonemenu ;;
	*Update*      ) tui up ;;
	*USB*         ) usbmenu ;;
	*Wallpaper*   ) wallpapermenu ;;
	*WLAN*        ) wlanmenu ;;
esac

#!/bin/sh

menu="\
箚쮪 Dashboard\n\
茶굟 Service\n\
箚엥 Subscription\n\
  ----\n\
箚뙓 Config local proxy\n\
箚뙔 Disable local proxy\n\
茶뒱 Enable local proxy\n\
箚뙕 Restart local proxy\n\
"

case $(printf "$menu" | menu -p "$(proxy)" "$@") in
	*Dashboard*    ) open http://192.168.1.1:9090/ui/metacubexd/#/proxies ;;
	*Service*      ) open http://192.168.1.1/cgi-bin/luci/admin/services/openclash ;;
	*Subscription* ) open http://127.0.0.1:3001/?api=http://127.0.0.1:3001/12345678910987654321 ;;
	*Config*       ) open http://127.0.0.1:9090/ui/#/proxies ;;
	*Disable*      ) tui "proxy disable" ;;
	*Enable*       ) tui "proxy enable" ;;
	*Restart*      ) tui "proxy restart" ;;
esac

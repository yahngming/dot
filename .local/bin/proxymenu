#!/bin/sh

menu="\
¾░©ć Gateway Dashboard\n\
¾▒éć Gateway Admin\n\
  ----\n\
¾░īś Config local proxy\n\
¾░īÖ Disable/stop local proxy\n\
¾▒Ŗ¬ Enable/start local proxy\n\
¾░īÜ Update/restart local proxy\n\
  ----\n\
¾░┐© Sub-Store\n\
’æź Subconverter\n\
"

case $(printf "$menu" | menu -p "$(proxy)" "$@") in
	*Dashboard*    ) xdg-open http://192.168.1.1:9090/ui/dashboard ;;
	*Admin*        ) xdg-open http://192.168.1.1/cgi-bin/luci/admin/services/openclash ;;
	*Config*       ) xdg-open http://127.0.0.1:9090/ui ;;
	*Disable*      ) tui "proxy off" ;;
	*Enable*       ) tui "proxy on" ;;
	*Update*       ) tui "proxy up" ;;
	*Sub-Store*    ) xdg-open http://127.0.0.1:3001/?api=http://127.0.0.1:3001/12345678910987654321 ;;
	*Subconverter* ) xdg-open http://127.0.0.1:25500/sub?url=http%3A%2F%2F127.0.0.1%3A3001%2F12345678910987654321%2Fdownload%2Fcollection%2Feverything\&config=https%3A%2F%2Fraw.githubusercontent.com%2Fyahngming%2Frules%2Fmaster%2Fsubconverter.ini\&upload=true\&target=clash ;;
esac

#!/bin/sh

menu="\
auto\n\
----\n\
arch\n\
clippy\n\
dos\n\
ibm\n\
invader\n\
thinkpad\n\
windows\n\
"

choice=$(printf "$menu" | menu "$@")
fetchfolder="$HOME/.config/fastfetch"
if [ "$choice" == "auto" ]; then
	case "$(cat /sys/devices/virtual/dmi/id/product_family)" in
		*ThinkPad* ) choice="thinkpad" ;;
	esac
	case "$(cat /sys/devices/virtual/dmi/id/product_name)" in
		*ITX*      ) choice="dos" ;;
		*          ) choice="arch" ;;
	esac
fi

[ -f $fetchfolder/config-$choice.jsonc ] &&	cp $fetchfolder/config-$choice.jsonc $fetchfolder/config.jsonc

#!/bin/sh

menu="\
auto\n\
----\n\
arch\n\
clippy\n\
dos\n\
ibm\n\
invader\n\
thinkpad\n\
windows\n\
"

choice=$(printf "$menu" | menu "$@")
if [ "$choice" == "auto" ]; then
	case "$(cat /sys/devices/virtual/dmi/id/product_family)" in
		*ThinkPad* ) choice="thinkpad" ;;
	esac
	case "$(cat /sys/devices/virtual/dmi/id/product_name)" in
		*ITX*      ) choice="dos" ;;
		*          ) choice="arch" ;;
	esac
fi
folder="$HOME/.config/fastfetch"

[[ -f $folder/config-$choice.jsonc ]] && cp $folder/config-$choice.jsonc $folder/config.jsonc

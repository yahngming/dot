#!/bin/sh

echo ""
echo "CPU"
echo "---"
lscpu | grep -E 'Model|MHz' | bat -fpPl cpuinfo

echo ""
echo "Memory"
echo "------"
free -h | bat -fpPl c

echo ""
echo "Storage"
echo "-------"
df -h | bat -fpPl c

echo ""
echo "Video Card"
echo "----------"
lspci | grep VGA | bat -fpPl cpuinfo

echo ""
echo "USB"
echo "---"
lsusb | bat -fpPl cpuinfo

echo ""
echo "Battery"
echo "-------"
bat=$(upower -e | grep BAT)
if [ -n "$bat" ]; then
	upower -i $bat | bat -fpPl cpuinfo
else
	echo "Not found."
fi

#!/bin/sh

image() {
	chafa -f sixels -s "$2x$3" --animate off --polite on "$1"
}

text() {
	bat --color=always --style=plain --pager=never "$1"
}

cachedir="$HOME/.cache/lf"
cachefile="$cachedir/thumbnail.$(sha256sum "$1" | awk '{print $1}').jpg"
mkdir -p "$cachedir"

case "${1##*.}" in
	diff)
		delta < "$1" && exit 0
		exit 1
		;;
	docx|pptx|xlsx)
		[ ! -f "${cachefile}" ] && libreoffice --headless --convert-to jpg --outdir "$cachedir" "$1" >/dev/null && mv "$cachedir/$(printf '%s\n' "$1" | sed 's|^.*/||; s|\..*$||').jpg" "$cachefile"
		image "${cachefile}" "$2" "$3" "$4" "$5" && exit 0
		exit 1
		;;
	htm|html|xhtml)
		w3m -dump "$1" && exit 0
		exit 1
		;;
	json)
		jq --color-output . "$1" && exit 0
		exit 1
		;;
	md)
		glow "$1" && exit 0
		exit 1
		;;
	pdf)
		[ ! -f "${cachefile}" ] && pdftoppm -jpeg -f 1 -singlefile "$1" "$cachefile" && mv "$cachefile.jpg" "$cachefile"
		image "${cachefile}" "$2" "$3" "$4" "$5" && exit 0
		exit 1
		;;
	svg)
		[ ! -f "${cachefile}" ] && convert "$1" "jpg:$cachefile"
		image "${cachefile}" "$2" "$3" "$4" "$5" && exit 0
		exit 1
		;;
esac

case "$(file -Lb --mime-type -- "$1")" in
	archive/*)
		atool --list -- "$1" && exit 0
		exit 1
		;;
	audio/*)
		[ ! -f "${cachefile}" ] && ffmpegthumbnailer -i "$1" -s 0 -q 50% -t 10 -o "$cachefile" 2>/dev/null
		exit 1
		;;
	image/*)
		image "$1" "$2" "$3" "$4" "$5" && exit 0
		exit 1
		;;
	text/*)
		text "$1" && exit 0
		exit 1
		;;
	video/*)
		[ ! -f "${cachefile}" ] && ffmpegthumbnailer -i "$1" -o "$cachefile" -s 0 -t 50% 2>/dev/null
		image "${cachefile}" "$2" "$3" "$4" "$5" && exit 0
		exit 1
		;;
esac

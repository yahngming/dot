#!/bin/sh

pkill $LAUNCHER && exit

menu="\
󰕮 System\n\
  ----\n\
󰄌 Battery\n\
 CPU\n\
󰢮 GPU\n\
 PCI\n\
 RAM\n\
 ROM\n\
󰊚 Sensors\n\
 Time\n\
󱊟 USB\n\
"

case $(printf "$menu" | menu "$@") in
	*System*  ) item="system" ;;
	*Battery* ) item="battery" ;;
	*CPU*     ) item="cpu" ;;
	*GPU*     ) item="gpu" ;;
	*PCI*     ) item="pci" ;;
	*RAM*     ) item="ram" ;;
	*ROM*     ) item="rom" ;;
	*Sensors* ) item="sensors" ;;
	*Time*    ) item="time" ;;
	*USB*     ) item="usb" ;;
esac

case "$item" in
	"" ) exit ;;
	*  ) pkill -f "read -n 1 -s"; tui "about $item; read -n 1 -s" ;;
esac
